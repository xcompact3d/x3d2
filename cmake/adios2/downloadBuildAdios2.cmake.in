cmake_minimum_required(VERSION @cmake_minimum_version@)
project(downloadBuildAdios2 NONE)

include(ExternalProject)

ExternalProject_Add(downloadBuildAdios2
    GIT_REPOSITORY    "https://github.com/ornladios/ADIOS2.git"
    GIT_TAG           "@adios2_git_tag@"
    SOURCE_DIR        "@adios2_src_dir@"
    BINARY_DIR        "@adios2_binary_dir@"
    INSTALL_DIR       "@adios2_install_dir@"
    CMAKE_ARGS
      -DCMAKE_INSTALL_PREFIX:PATH=@adios2_install_dir@
      -DADIOS2_BUILD_EXAMPLES=OFF
      -DADIOS2_BUILD_TESTING=OFF
      -DADIOS2_USE_Fortran=ON
      -DADIOS2_USE_CUDA=@X3D2_ADIOS2_CUDA@
)

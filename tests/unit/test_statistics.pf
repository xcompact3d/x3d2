! pFUnit tests for accumulate_mean in m_stats

@test
subroutine test_constant_field()
   use funit
   use m_common, only: dp
   use m_stats, only: accumulate_mean
   implicit none

   real(dp), parameter :: c = 1.0_dp
   integer, parameter :: n_samples = 100
   real(dp), parameter :: tol = 1.0e-12_dp
   real(dp) :: umean(1, 1, 1), uumean(1, 1, 1), val(1, 1, 1)
   real(dp) :: uprime, stat_inc
   integer :: n

   umean = 0.0_dp; uumean = 0.0_dp

   do n = 1, n_samples
      stat_inc = 1.0_dp/n
      val(1, 1, 1) = c
      call accumulate_mean(umean, val, stat_inc)
      val(1, 1, 1) = c*c
      call accumulate_mean(uumean, val, stat_inc)
   end do

   uprime = sqrt(max(0.0_dp, uumean(1, 1, 1) - umean(1, 1, 1)**2))

   @assertEqual(c, umean(1, 1, 1), tol, 'umean should equal constant')
   @assertEqual(0.0_dp, uprime, tol, 'uprime should be zero for constant field')
end subroutine

@test
subroutine test_known_mean()
   use funit
   use m_common, only: dp
   use m_stats, only: accumulate_mean
   implicit none

   integer, parameter :: n_samples = 50
   real(dp), parameter :: tol = 1.0e-12_dp
   real(dp) :: umean(1, 1, 1), val(1, 1, 1)
   real(dp) :: stat_inc, expected
   integer :: n

   umean = 0.0_dp
   expected = (n_samples + 1)/2.0_dp

   do n = 1, n_samples
      stat_inc = 1.0_dp/n
      val(1, 1, 1) = real(n, dp)
      call accumulate_mean(umean, val, stat_inc)
   end do

   @assertEqual(expected, umean(1, 1, 1), tol, 'mean of 1..N should be (N+1)/2')
end subroutine

@test
subroutine test_rms_nonzero()
   use funit
   use m_common, only: dp
   use m_stats, only: accumulate_mean
   implicit none

   integer, parameter :: n_samples = 200
   real(dp), parameter :: tol = 1.0e-10_dp
   real(dp) :: umean(1, 1, 1), uumean(1, 1, 1), val(1, 1, 1)
   real(dp) :: uprime, stat_inc
   integer :: n

   umean = 0.0_dp; uumean = 0.0_dp

   do n = 1, n_samples
      val(1, 1, 1) = merge(1.0_dp, -1.0_dp, mod(n, 2) == 0)
      stat_inc = 1.0_dp/n
      call accumulate_mean(umean, val, stat_inc)
      val(1, 1, 1) = val(1, 1, 1)**2
      call accumulate_mean(uumean, val, stat_inc)
   end do

   uprime = sqrt(max(0.0_dp, uumean(1, 1, 1) - umean(1, 1, 1)**2))

   @assertEqual(0.0_dp, umean(1, 1, 1), tol, 'mean of alternating +/-1 should be 0')
   @assertEqual(1.0_dp, uprime, tol, 'rms of alternating +/-1 should be 1')
end subroutine

@test
subroutine test_reynolds_stress_correlated()
   use funit
   use m_common, only: dp
   use m_stats, only: accumulate_mean
   implicit none

   integer, parameter :: n_samples = 100
   real(dp), parameter :: tol = 1.0e-10_dp
   real(dp) :: umean(1, 1, 1), vmean(1, 1, 1)
   real(dp) :: uumean(1, 1, 1), uvmean(1, 1, 1)
   real(dp) :: val(1, 1, 1), stat_inc
   real(dp) :: uprime2, reynolds_stress, eps
   integer :: n

   umean = 0.0_dp; vmean = 0.0_dp
   uumean = 0.0_dp; uvmean = 0.0_dp

   do n = 1, n_samples
      stat_inc = 1.0_dp/n
      val(1, 1, 1) = real(n, dp)
      call accumulate_mean(umean, val, stat_inc)
      call accumulate_mean(vmean, val, stat_inc)
      val(1, 1, 1) = real(n, dp)**2
      call accumulate_mean(uumean, val, stat_inc)
      call accumulate_mean(uvmean, val, stat_inc)
   end do

   uprime2 = uumean(1, 1, 1) - umean(1, 1, 1)**2
   reynolds_stress = uvmean(1, 1, 1) - umean(1, 1, 1)*vmean(1, 1, 1)
   eps = tol*abs(uprime2)

   @assertEqual(uprime2, reynolds_stress, eps, 'Reynolds stress = variance for u==v')
end subroutine

@test
subroutine test_reynolds_stress_anticorrelated()
   use funit
   use m_common, only: dp
   use m_stats, only: accumulate_mean
   implicit none

   integer, parameter :: n_samples = 100
   real(dp), parameter :: tol = 1.0e-10_dp
   real(dp) :: umean(1, 1, 1), vmean(1, 1, 1)
   real(dp) :: uumean(1, 1, 1), uvmean(1, 1, 1)
   real(dp) :: val(1, 1, 1), stat_inc
   real(dp) :: uprime2, reynolds_stress, expected, eps
   integer :: n

   umean = 0.0_dp; vmean = 0.0_dp
   uumean = 0.0_dp; uvmean = 0.0_dp

   do n = 1, n_samples
      stat_inc = 1.0_dp/n
      val(1, 1, 1) = real(n, dp)
      call accumulate_mean(umean, val, stat_inc)
      val(1, 1, 1) = -real(n, dp)
      call accumulate_mean(vmean, val, stat_inc)
      val(1, 1, 1) = real(n, dp)**2
      call accumulate_mean(uumean, val, stat_inc)
      val(1, 1, 1) = -real(n, dp)**2
      call accumulate_mean(uvmean, val, stat_inc)
   end do

   uprime2 = uumean(1, 1, 1) - umean(1, 1, 1)**2
   reynolds_stress = uvmean(1, 1, 1) - umean(1, 1, 1)*vmean(1, 1, 1)
   expected = -uprime2
   eps = tol*abs(uprime2)

   @assertEqual(expected, reynolds_stress, eps, 'Reynolds stress = -variance for u==-v')
end subroutine

! pFUnit tests for reorder map lookups in m_common

@test
subroutine test_get_dirs_from_rdr_x2y()
   use funit
   use m_common, only: RDR_X2Y, DIR_X, DIR_Y, get_dirs_from_rdr
   implicit none
   integer :: dir_from, dir_to
   call get_dirs_from_rdr(dir_from, dir_to, RDR_X2Y)
   @assertEqual(DIR_X, dir_from)
   @assertEqual(DIR_Y, dir_to)
end subroutine


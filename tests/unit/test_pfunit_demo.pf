! This is a pFUnit test file (.pf)
! It allows testing specific subroutines in isolation.

@test
subroutine test_basic_assertion()
   use funit
   implicit none

   ! Verify that 1 equals 1 (Sanity check)
   @assertEqual(1, 1)
end subroutine

@test
subroutine test_real_comparison()
   use funit
   implicit none
   real(kind=selected_real_kind(15)) :: a, b

   a = 1.0d0
   b = 1.0d0 + 1.0d-15
   @assertEqual(a, b, 1.0d-12, 'reals should be approximately equal')
end subroutine

! pFUnit tests for mesh_t
! Note: Only tests generic decomposition (not 2decomp) since pFUnit
! does not support preprocessor guards (#ifdef WITH_2DECOMPFFT).
! The standalone test_mesh.f90 continues to test 2decomp decomposition.

@mpitest(npes=[4])
subroutine test_mesh_get_n_cell_vert(this)
   use pfunit
   use m_common, only: dp, DIR_X, DIR_Z, CELL, VERT, Z_FACE
   use m_allocator, only: allocator_t
   use m_field, only: field_t
   use m_mesh, only: mesh_t
   implicit none
   class(MpiTestMethod), intent(inout) :: this

   integer, dimension(3) :: nproc_dir, dims_global
   real(dp), dimension(3) :: L_global
   character(len=20) :: BC_x(2), BC_y(2), BC_z(2)
   class(allocator_t), allocatable :: allocator
   class(mesh_t), allocatable :: mesh
   class(field_t), pointer :: ptr_cell, ptr_vert
   integer :: n_cell, n_vert

   dims_global = [4, 4, 16]
   L_global = [1._dp, 1._dp, 1._dp]
   nproc_dir = [1, 1, 4]

   BC_x = [character(len=20) :: 'neumann', 'dirichlet']
   BC_y = [character(len=20) :: 'periodic', 'periodic']
   BC_z = [character(len=20) :: 'dirichlet', 'neumann']

   mesh = mesh_t(dims_global, nproc_dir, L_global, BC_x, BC_y, BC_z, &
                 use_2decomp=.false.)

   allocator = allocator_t(mesh%get_dims(VERT), 8)

   ptr_cell => allocator%get_block(DIR_Z, CELL)
   ptr_vert => allocator%get_block(DIR_Z, VERT)

   n_cell = mesh%get_n(ptr_cell)
   n_vert = mesh%get_n(ptr_vert)

   ! Generic decomposition: all ranks get 4 vertices in z
   if (mesh%par%nrank == 3) then
      ! Last rank: n_cell = n_vert - 1 for non-periodic BC
      @assertEqual(3, n_cell, 'last rank n_cell should be 3')
      @assertEqual(4, n_vert, 'last rank n_vert should be 4')
   else
      @assertEqual(4, n_cell, 'n_cell should be 4')
      @assertEqual(4, n_vert, 'n_vert should be 4')
   end if

   call allocator%destroy()
end subroutine

@mpitest(npes=[4])
subroutine test_mesh_get_n_face(this)
   use pfunit
   use m_common, only: dp, DIR_X, DIR_Z, VERT, Z_FACE
   use m_allocator, only: allocator_t
   use m_field, only: field_t
   use m_mesh, only: mesh_t
   implicit none
   class(MpiTestMethod), intent(inout) :: this

   integer, dimension(3) :: nproc_dir, dims_global
   real(dp), dimension(3) :: L_global
   character(len=20) :: BC_x(2), BC_y(2), BC_z(2)
   class(allocator_t), allocatable :: allocator
   class(mesh_t), allocatable :: mesh
   class(field_t), pointer :: ptr_face
   integer :: n_x_face

   dims_global = [4, 4, 16]
   L_global = [1._dp, 1._dp, 1._dp]
   nproc_dir = [1, 1, 4]

   BC_x = [character(len=20) :: 'neumann', 'dirichlet']
   BC_y = [character(len=20) :: 'periodic', 'periodic']
   BC_z = [character(len=20) :: 'dirichlet', 'neumann']

   mesh = mesh_t(dims_global, nproc_dir, L_global, BC_x, BC_y, BC_z, &
                 use_2decomp=.false.)

   allocator = allocator_t(mesh%get_dims(VERT), 8)
   ptr_face => allocator%get_block(DIR_X, Z_FACE)

   n_x_face = mesh%get_n(ptr_face)
   @assertEqual(3, n_x_face, 'n_x_face should be 3')

   call allocator%destroy()
end subroutine

@mpitest(npes=[4])
subroutine test_mesh_grid_spacing(this)
   use pfunit
   use m_common, only: dp, DIR_Y, DIR_Z, VERT
   use m_mesh, only: mesh_t
   implicit none
   class(MpiTestMethod), intent(inout) :: this

   integer, dimension(3) :: nproc_dir, dims_global
   real(dp), dimension(3) :: L_global
   character(len=20) :: BC_x(2), BC_y(2), BC_z(2)
   class(mesh_t), allocatable :: mesh
   real(dp), parameter :: eps = 1e-8_dp

   dims_global = [4, 4, 16]
   L_global = [1._dp, 1._dp, 1._dp]
   nproc_dir = [1, 1, 4]

   BC_x = [character(len=20) :: 'neumann', 'dirichlet']
   BC_y = [character(len=20) :: 'periodic', 'periodic']
   BC_z = [character(len=20) :: 'dirichlet', 'neumann']

   mesh = mesh_t(dims_global, nproc_dir, L_global, BC_x, BC_y, BC_z, &
                 use_2decomp=.false.)

   ! Non-periodic BC: d = L/(N-1)
   @assertEqual(1._dp/15._dp, mesh%geo%d(DIR_Z), eps, 'non-periodic grid spacing')

   ! Periodic BC: d = L/N
   @assertEqual(1._dp/4._dp, mesh%geo%d(DIR_Y), eps, 'periodic grid spacing')
end subroutine

@mpitest(npes=[4])
subroutine test_mesh_padded_dims(this)
   use pfunit
   use m_common, only: dp, DIR_C, VERT
   use m_allocator, only: allocator_t
   use m_mesh, only: mesh_t
   implicit none
   class(MpiTestMethod), intent(inout) :: this

   integer, dimension(3) :: nproc_dir, dims_global, dims, dims_expected
   real(dp), dimension(3) :: L_global
   character(len=20) :: BC_x(2), BC_y(2), BC_z(2)
   class(allocator_t), allocatable :: allocator
   class(mesh_t), allocatable :: mesh

   dims_global = [4, 4, 16]
   L_global = [1._dp, 1._dp, 1._dp]
   nproc_dir = [1, 1, 4]

   BC_x = [character(len=20) :: 'neumann', 'dirichlet']
   BC_y = [character(len=20) :: 'periodic', 'periodic']
   BC_z = [character(len=20) :: 'dirichlet', 'neumann']

   mesh = mesh_t(dims_global, nproc_dir, L_global, BC_x, BC_y, BC_z, &
                 use_2decomp=.false.)

   allocator = allocator_t(mesh%get_dims(VERT), 8)

   dims = allocator%get_padded_dims(DIR_C)
   dims_expected = [8, 8, 4]  ! Generic decomposition: all ranks get 4

   @assertEqual(dims_expected, dims, 'padded dims in DIR_C')

   call allocator%destroy()
end subroutine
